---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export const getStaticPaths = (async ({ paginate }) => {
  const all = await getCollection('news');
  const tagSet = new Set<string>();
  for (const e of all) for (const t of e.data.tags) tagSet.add(t);

  const paths = [];
  for (const tag of tagSet) {
    const items = all
      .filter((e) => e.data.tags.includes(tag))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    paths.push(...paginate(items, { pageSize: 20, params: { tag } }));
  }
  return paths;
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { page, tag } = Astro.props as { page: Props['page']; tag: string };
---

<Base title={`#${tag} · 每日资讯`}>
  <h1>#{tag}</h1>
  {page.data.map((entry) => (
    <article class="post">
      <h2>
        <a href={`/news/${entry.id}/`}>{entry.data.title}</a>
      </h2>
      <div class="post-meta">
        <a href={entry.data.url} rel="noopener">{entry.data.source}</a>
        {' · '}
        <time>{entry.data.date.toISOString().slice(0, 10)}</time>
      </div>
    </article>
  ))}

  <nav class="pagination">
    {page.url.prev && <a href={page.url.prev}>← 上一页</a>}
    <span>{page.currentPage} / {page.lastPage}</span>
    {page.url.next && <a href={page.url.next}>下一页 →</a>}
  </nav>
</Base>
