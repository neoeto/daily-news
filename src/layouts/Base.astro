---
import '../styles/global.css';
import Search from '../components/Search.astro';

interface Props {
  title?: string;
  description?: string;
  variant?: 'list' | 'read';
}
const {
  title = '每日资讯',
  description = '个人资讯聚合 · 中英文科技周刊',
  variant = 'list',
} = Astro.props;
const wrapClass = variant === 'read' ? 'wrap-read' : 'wrap-list';
const now = new Date();
const dateLabel = `${now.getFullYear()} 年 ${now.getMonth() + 1} 月 ${now.getDate()} 日`;
---

<!doctype html>
<html lang="zh" class="no-js">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      document.documentElement.className = document.documentElement.className.replace(
        /\bno-js\b/,
        'js',
      );
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={title} href="/rss.xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="masthead">
      <div class="wrap masthead-inner">
        <a href="/" class="masthead-title">每日资讯</a>
        <nav class="masthead-nav">
          <a href="/">首页</a>
          <a href="/tags">标签</a>
          <a href="/bookmarks">收藏</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
    </header>

    <main class={wrapClass}>
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap">
        <Search />
        <p class="colophon">
          {dateLabel} · GitHub Actions 抓取与翻译 · Astro 构建 · Cloudflare Pages 托管
        </p>
      </div>
    </footer>

    <script>
      // Reading-state bootstrap: reflects persistent state onto every article
      // card on the page by setting data-read / data-starred attributes. The
      // CSS in global.css turns these into visual treatments (grayed-out title,
      // ★ prefix). Runs once on load, then re-applies on every store change so
      // list/detail instances stay in sync.
      import { subscribe, getState } from '../scripts/reading-state';

      function applyReadingState(): void {
        const state = getState();
        document.querySelectorAll<HTMLElement>('[data-url-hash]').forEach((el) => {
          const hash = el.dataset.urlHash;
          if (!hash) return;
          if (hash in state.read) el.setAttribute('data-read', 'true');
          else el.removeAttribute('data-read');
          if (hash in state.starred) el.setAttribute('data-starred', 'true');
          else el.removeAttribute('data-starred');
        });
      }

      applyReadingState();
      subscribe(applyReadingState);
    </script>
  </body>
</html>
