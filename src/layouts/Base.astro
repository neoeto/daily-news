---
import '../styles/global.css';
import Search from '../components/Search.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title = '每日资讯', description = '个人资讯聚合' } = Astro.props;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title={title} href="/rss.xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">{title}</a>
        <nav class="site-nav">
          <a href="/">首页</a>
          <a href="/tags">标签</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <Search />
        <p>由 GitHub Actions 抓取 · Astro 构建 · Cloudflare Pages 托管</p>
      </div>
    </footer>
  </body>
</html>
