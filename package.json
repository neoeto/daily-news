{
  "name": "daily-news",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "个人资讯聚合:GitHub Actions 抓取翻译打标 + Astro 静态站点 + Cloudflare Pages 托管",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test crawler/test/*.test.ts cli/test/*.test.ts shared/test/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "crawl": "tsx crawler/src/index.ts",
    "add-source": "tsx cli/src/add-source.ts",
    "build": "astro build && pagefind --site dist",
    "dev": "astro dev",
    "preview": "astro preview"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.18.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3"
  }
}
